# Anthropic API Key (required)
ANTHROPIC_API_KEY=your-api-key-here

# Anthropic API Base URL (optional, defaults to https://api.minimaxi.com/anthropic)
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic

# Server port (optional, defaults to 53220)
PORT=53220

# Default model when client doesn't specify (optional)
DEFAULT_MODEL=MiniMax-M2.7-highspeed

# Default reasoning effort level (optional, defaults to 'none')
# Options: none, minimal, low, medium, high, xhigh
DEFAULT_REASONING_EFFORT=none

# Log directory - set to enable file logging, leave empty for console only (optional)
LOG_DIR=./logs
